# Copy to .env and fill in — never commit .env

# Gemini API (image generation, Nano Banana Pro)
GEMINI_API_KEY=AIza...

# Google Cloud Text-to-Speech (Chirp 3 HD voices)
# Path to a service-account JSON file with role "Cloud Text-to-Speech User".
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/gcp-tts-sa.json

# Telegram preview bot
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=

PODCAST_BASE_URL=https://enabridge.ai/research
PODCAST_TITLE=Enabridge Daily AI Brief
PODCAST_AUTHOR=Yoh / Enabridge
